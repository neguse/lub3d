// Jolt Physics — lub3d binding via CppClass pipeline
// JoltWorld wraps JPH::PhysicsSystem + subsystems into a single opaque type.
// Complex operations (multi-return, constructor with optional params) are in ExtraCCode.
[Prefix="jolt_", IsCpp, EntryPoint="luaopen_jolt", StandaloneEntry,
ExtraCCode="extra/jolt_extra.cpp",
ExtraLuaReg="World:l_jolt_World_new"]

// ===== Enums =====

enum EMotionType {
    "EMotionType_Static" = 0,
    "EMotionType_Kinematic" = 1,
    "EMotionType_Dynamic" = 2
};

enum EActivation {
    "EActivation_Activate" = 0,
    "EActivation_DontActivate" = 1
};

enum EBodyType {
    "EBodyType_RigidBody" = 0,
    "EBodyType_SoftBody" = 1
};

enum EMotionQuality {
    "EMotionQuality_Discrete" = 0,
    "EMotionQuality_LinearCast" = 1
};

enum EOverrideMassProperties {
    "EOverrideMassProperties_CalculateMassAndInertia" = 0,
    "EOverrideMassProperties_CalculateInertia" = 1,
    "EOverrideMassProperties_MassAndInertiaProvided" = 2
};

enum EAllowedDOFs {
    "EAllowedDOFs_All" = 63,
    "EAllowedDOFs_TranslationX" = 1,
    "EAllowedDOFs_TranslationY" = 2,
    "EAllowedDOFs_TranslationZ" = 4,
    "EAllowedDOFs_RotationX" = 8,
    "EAllowedDOFs_RotationY" = 16,
    "EAllowedDOFs_RotationZ" = 32,
    "EAllowedDOFs_Plane2D" = 41
};

enum EShapeType {
    "EShapeType_Convex" = 0,
    "EShapeType_Compound" = 1,
    "EShapeType_Decorated" = 2,
    "EShapeType_Mesh" = 3,
    "EShapeType_HeightField" = 4,
    "EShapeType_SoftBody" = 5,
    "EShapeType_Plane" = 10,
    "EShapeType_Empty" = 11
};

enum EShapeSubType {
    "EShapeSubType_Sphere" = 0,
    "EShapeSubType_Box" = 1,
    "EShapeSubType_Capsule" = 3,
    "EShapeSubType_TaperedCapsule" = 4,
    "EShapeSubType_Cylinder" = 5,
    "EShapeSubType_ConvexHull" = 6,
    "EShapeSubType_StaticCompound" = 7,
    "EShapeSubType_MutableCompound" = 8,
    "EShapeSubType_RotatedTranslated" = 9,
    "EShapeSubType_Scaled" = 10,
    "EShapeSubType_OffsetCenterOfMass" = 11,
    "EShapeSubType_Mesh" = 12,
    "EShapeSubType_HeightField" = 13,
    "EShapeSubType_SoftBody" = 14,
    "EShapeSubType_Plane" = 31,
    "EShapeSubType_TaperedCylinder" = 32,
    "EShapeSubType_Empty" = 33
};

enum EBackFaceMode {
    "EBackFaceMode_IgnoreBackFaces" = 0,
    "EBackFaceMode_CollideWithBackFaces" = 1
};

enum EActiveEdgeMode {
    "EActiveEdgeMode_CollideOnlyWithActive" = 0,
    "EActiveEdgeMode_CollideWithAll" = 1
};

enum ECollectFacesMode {
    "ECollectFacesMode_CollectFaces" = 0,
    "ECollectFacesMode_NoFaces" = 1
};

enum EConstraintSpace {
    "EConstraintSpace_LocalToBodyCOM" = 0,
    "EConstraintSpace_WorldSpace" = 1
};

enum EConstraintType {
    "EConstraintType_Constraint" = 0,
    "EConstraintType_TwoBodyConstraint" = 1
};

enum EConstraintSubType {
    "EConstraintSubType_Fixed" = 0,
    "EConstraintSubType_Point" = 1,
    "EConstraintSubType_Hinge" = 2,
    "EConstraintSubType_Slider" = 3,
    "EConstraintSubType_Distance" = 4,
    "EConstraintSubType_Cone" = 5,
    "EConstraintSubType_SwingTwist" = 6,
    "EConstraintSubType_SixDOF" = 7,
    "EConstraintSubType_Path" = 8,
    "EConstraintSubType_Vehicle" = 9,
    "EConstraintSubType_RackAndPinion" = 10,
    "EConstraintSubType_Gear" = 11,
    "EConstraintSubType_Pulley" = 12
};

enum EMotorState {
    "EMotorState_Off" = 0,
    "EMotorState_Velocity" = 1,
    "EMotorState_Position" = 2
};

enum ESwingType {
    "ESwingType_Cone" = 0,
    "ESwingType_Pyramid" = 1
};

enum ESpringMode {
    "ESpringMode_FrequencyAndDamping" = 0,
    "ESpringMode_StiffnessAndDamping" = 1
};

enum EPathRotationConstraintType {
    "EPathRotationConstraintType_Free" = 0,
    "EPathRotationConstraintType_ConstrainAroundTangent" = 1,
    "EPathRotationConstraintType_ConstrainAroundNormal" = 2,
    "EPathRotationConstraintType_ConstrainAroundBinormal" = 3,
    "EPathRotationConstraintType_ConstrainToPath" = 4,
    "EPathRotationConstraintType_FullyConstrained" = 5
};

enum SixDOFConstraintSettings_EAxis {
    "SixDOFConstraintSettings_EAxis_TranslationX" = 0,
    "SixDOFConstraintSettings_EAxis_TranslationY" = 1,
    "SixDOFConstraintSettings_EAxis_TranslationZ" = 2,
    "SixDOFConstraintSettings_EAxis_RotationX" = 3,
    "SixDOFConstraintSettings_EAxis_RotationY" = 4,
    "SixDOFConstraintSettings_EAxis_RotationZ" = 5
};

enum EGroundState {
    "EGroundState_OnGround" = 0,
    "EGroundState_OnSteepGround" = 1,
    "EGroundState_NotSupported" = 2,
    "EGroundState_InAir" = 3
};

enum EStateRecorderState {
    "EStateRecorderState_None" = 0,
    "EStateRecorderState_Global" = 1,
    "EStateRecorderState_Bodies" = 2,
    "EStateRecorderState_Contacts" = 4,
    "EStateRecorderState_Constraints" = 8,
    "EStateRecorderState_All" = 15
};

enum ETransmissionMode {
    "ETransmissionMode_Auto" = 0,
    "ETransmissionMode_Manual" = 1
};

enum ValidateResult {
    "ValidateResult_AcceptAllContactsForThisBodyPair" = 0,
    "ValidateResult_AcceptContact" = 1,
    "ValidateResult_RejectContact" = 2,
    "ValidateResult_RejectAllContactsForThisBodyPair" = 3
};

enum SoftBodyValidateResult {
    "SoftBodyValidateResult_AcceptContact" = 0,
    "SoftBodyValidateResult_RejectContact" = 1
};

enum SoftBodySharedSettings_EBendType {
    "SoftBodySharedSettings_EBendType_None" = 0,
    "SoftBodySharedSettings_EBendType_Distance" = 1,
    "SoftBodySharedSettings_EBendType_Dihedral" = 2
};

enum SoftBodySharedSettings_ELRAType {
    "SoftBodySharedSettings_ELRAType_None" = 0,
    "SoftBodySharedSettings_ELRAType_EuclideanDistance" = 1,
    "SoftBodySharedSettings_ELRAType_GeodesicDistance" = 2
};

enum MeshShapeSettings_EBuildQuality {
    "MeshShapeSettings_EBuildQuality_FavorRuntimePerformance" = 0,
    "MeshShapeSettings_EBuildQuality_FavorBuildSpeed" = 1
};

// ===== Math ValueTypes =====

[CppClass="JPH::Vec3", ValueType]
interface Vec3 {
    [Constructor]
    void create(float x, float y, float z);
    float GetX();
    float GetY();
    float GetZ();
    void SetX(float v);
    void SetY(float v);
    void SetZ(float v);
    void Set(float x, float y, float z);
    float Length();
    float LengthSq();
    Vec3 Normalized();
    Vec3 Cross(Vec3 v);
    float Dot(Vec3 v);
    Vec3 Abs();
    Vec3 GetSign();
};

[CppClass="JPH::RVec3", ValueType]
interface RVec3 {
    [Constructor]
    void create(double x, double y, double z);
    double GetX();
    double GetY();
    double GetZ();
    void SetX(double v);
    void SetY(double v);
    void SetZ(double v);
    void Set(double x, double y, double z);
    double Length();
    double LengthSq();
    RVec3 Normalized();
    RVec3 Cross(RVec3 v);
    double Dot(RVec3 v);
    RVec3 Abs();
};

[CppClass="JPH::Quat", ValueType]
interface Quat {
    [Constructor]
    void create(float x, float y, float z, float w);
    float GetX();
    float GetY();
    float GetZ();
    float GetW();
    void SetX(float v);
    void SetY(float v);
    void SetZ(float v);
    void SetW(float v);
    float Length();
    float LengthSq();
    Quat Normalized();
    Quat Conjugated();
    Quat Inversed();
    float Dot(Quat q);
    Vec3 GetEulerAngles();
    Vec3 RotateAxisX();
    Vec3 RotateAxisY();
    Vec3 RotateAxisZ();
    Vec3 InverseRotate(Vec3 v);
};

[CppClass="JPH::Mat44", ValueType]
interface Mat44 {
    [Constructor]
    void create();
    Vec3 GetAxisX();
    Vec3 GetAxisY();
    Vec3 GetAxisZ();
    Vec3 GetTranslation();
    void SetTranslation(Vec3 v);
    Quat GetQuaternion();
    Mat44 Inversed();
    Mat44 Transposed();
    Vec3 Multiply3x3(Vec3 v);
    float GetDeterminant3x3();
};

[CppClass="JPH::RMat44", ValueType]
interface RMat44 {
    [Constructor]
    void create();
    Vec3 GetAxisX();
    Vec3 GetAxisY();
    Vec3 GetAxisZ();
    RVec3 GetTranslation();
    void SetTranslation(RVec3 v);
    Quat GetQuaternion();
    RMat44 Inversed();
    Vec3 Multiply3x3(Vec3 v);
};

[CppClass="JPH::Float2", ValueType]
interface Vector2 {
    [Constructor]
    void create(float x, float y);
};

[CppClass="JPH::Float3", ValueType]
interface Float3 {
    [Constructor]
    void create(float x, float y, float z);
};

[CppClass="JPH::Vec4", ValueType]
interface Vec4 {
    [Constructor]
    void create(float x, float y, float z, float w);
    float GetX();
    float GetY();
    float GetZ();
    float GetW();
    void SetX(float v);
    void SetY(float v);
    void SetZ(float v);
    void SetW(float v);
    void Set(float x, float y, float z, float w);
};

[CppClass="JPH::Plane", ValueType]
interface Plane {
    [Constructor]
    void create(Vec3 normal, float constant);
    Vec3 GetNormal();
    void SetNormal(Vec3 normal);
    float GetConstant();
    void SetConstant(float constant);
    float SignedDistance(Vec3 point);
};

[CppClass="JPH::AABox", ValueType]
interface AABox {
    [Constructor]
    void create(Vec3 min, Vec3 max);
    void SetEmpty();
    boolean IsValid();
    Vec3 GetCenter();
    Vec3 GetExtent();
    Vec3 GetSize();
    float GetSurfaceArea();
    float GetVolume();
    void ExpandBy(Vec3 v);
};

[CppClass="JPH::OrientedBox", ValueType]
interface OrientedBox {
    [Constructor]
    void create(Mat44 orientation, Vec3 halfExtents);
};

[CppClass="JPH::Triangle", ValueType]
interface Triangle {
    [Constructor]
    void create();
};

[CppClass="JPH::IndexedTriangle", ValueType]
interface IndexedTriangle {
    [Constructor]
    void create(unsigned long i1, unsigned long i2, unsigned long i3,
    unsigned long materialIndex);
};

// ===== Body types =====

[CppClass="JPH::BodyID", ValueType]
interface BodyID {
    [Constructor]
    void create(unsigned long indexAndSequenceNumber);
    unsigned long GetIndex();
    unsigned long GetIndexAndSequenceNumber();
};

[CppClass="JPH::Body", NoDelete]
interface Body {
    BodyID GetID();
    boolean IsActive();
    boolean IsStatic();
    boolean IsKinematic();
    boolean IsDynamic();
    boolean IsRigidBody();
    boolean IsSoftBody();
    EBodyType GetBodyType();
    EMotionType GetMotionType();
    boolean IsSensor();
    void SetIsSensor(boolean v);
    float GetFriction();
    void SetFriction(float v);
    float GetRestitution();
    void SetRestitution(float v);
    Vec3 GetLinearVelocity();
    void SetLinearVelocity(Vec3 v);
    Vec3 GetAngularVelocity();
    void SetAngularVelocity(Vec3 v);
    void AddForce(Vec3 force);
    void AddTorque(Vec3 torque);
    void AddImpulse(Vec3 impulse);
    void AddAngularImpulse(Vec3 impulse);
    void ResetForce();
    void ResetTorque();
    void ResetMotion();
    RVec3 GetPosition();
    Quat GetRotation();
    RMat44 GetWorldTransform();
    RVec3 GetCenterOfMassPosition();
    Vec3 GetAccumulatedForce();
    Vec3 GetAccumulatedTorque();
    boolean GetAllowSleeping();
    void SetAllowSleeping(boolean v);
    void ResetSleepTimer();
    unsigned long long GetUserData();
    void SetUserData(unsigned long long data);
    MotionProperties GetMotionProperties();
};

[CppClass="JPH::MotionProperties", NoDelete]
interface MotionProperties {
    EMotionQuality GetMotionQuality();
    Vec3 GetLinearVelocity();
    void SetLinearVelocity(Vec3 v);
    Vec3 GetAngularVelocity();
    void SetAngularVelocity(Vec3 v);
    float GetMaxLinearVelocity();
    void SetMaxLinearVelocity(float v);
    float GetMaxAngularVelocity();
    void SetMaxAngularVelocity(float v);
    float GetLinearDamping();
    void SetLinearDamping(float v);
    float GetAngularDamping();
    void SetAngularDamping(float v);
    float GetGravityFactor();
    void SetGravityFactor(float v);
    float GetInverseMass();
    void SetInverseMass(float v);
    Vec3 GetAccumulatedForce();
    Vec3 GetAccumulatedTorque();
    void ResetForce();
    void ResetTorque();
    void ResetMotion();
};

[CppClass="JPH::MassProperties", ValueType]
interface MassProperties {
    [Constructor]
    void create();
    void SetMassAndInertiaOfSolidBox(Vec3 halfExtents, float density);
    void ScaleToMass(float mass);
    void Rotate(Mat44 rotation);
    void Translate(Vec3 translation);
    void Scale(Vec3 scale);
};

[CppClass="JPH::BodyCreationSettings", ValueType]
interface BodyCreationSettings {
    [Constructor]
    void create();
};

// ===== BodyInterface =====

[CppClass="JPH::BodyInterface", NoDelete]
interface BodyInterface {
    void DestroyBody(BodyID bodyID);
    void AddBody(BodyID bodyID, EActivation activationMode);
    void RemoveBody(BodyID bodyID);
    boolean IsAdded(BodyID bodyID);
    BodyID CreateAndAddBody(BodyCreationSettings settings, EActivation activationMode);
    void SetPosition(BodyID bodyID, RVec3 position, EActivation activationMode);
    RVec3 GetPosition(BodyID bodyID);
    void SetRotation(BodyID bodyID, Quat rotation, EActivation activationMode);
    Quat GetRotation(BodyID bodyID);
    RMat44 GetWorldTransform(BodyID bodyID);
    RMat44 GetCenterOfMassTransform(BodyID bodyID);
    void SetLinearVelocity(BodyID bodyID, Vec3 linearVelocity);
    Vec3 GetLinearVelocity(BodyID bodyID);
    void SetAngularVelocity(BodyID bodyID, Vec3 angularVelocity);
    Vec3 GetAngularVelocity(BodyID bodyID);
    Vec3 GetPointVelocity(BodyID bodyID, RVec3 point);
    void ActivateBody(BodyID bodyID);
    void DeactivateBody(BodyID bodyID);
    boolean IsActive(BodyID bodyID);
    void SetMotionType(BodyID bodyID, EMotionType motionType, EActivation activationMode);
    EMotionType GetMotionType(BodyID bodyID);
    void SetMotionQuality(BodyID bodyID, EMotionQuality motionQuality);
    EMotionQuality GetMotionQuality(BodyID bodyID);
    Mat44 GetInverseInertia(BodyID bodyID);
    void SetRestitution(BodyID bodyID, float restitution);
    float GetRestitution(BodyID bodyID);
    void SetFriction(BodyID bodyID, float friction);
    float GetFriction(BodyID bodyID);
    void SetGravityFactor(BodyID bodyID, float factor);
    float GetGravityFactor(BodyID bodyID);
    void SetMaxLinearVelocity(BodyID bodyID, float linearVelocity);
    float GetMaxLinearVelocity(BodyID bodyID);
    void SetMaxAngularVelocity(BodyID bodyID, float angularVelocity);
    float GetMaxAngularVelocity(BodyID bodyID);
    void AddImpulse(BodyID bodyID, Vec3 impulse);
    void AddAngularImpulse(BodyID bodyID, Vec3 angularImpulse);
    EBodyType GetBodyType(BodyID bodyID);
    void SetIsSensor(BodyID bodyID, boolean isSensor);
    boolean IsSensor(BodyID bodyID);
    void ResetSleepTimer(BodyID bodyID);
    unsigned long long GetUserData(BodyID bodyID);
    void SetUserData(BodyID bodyID, unsigned long long userData);
    void InvalidateContactCache(BodyID bodyID);
};

[CppClass="JPH::TransformedShape", ValueType]
interface TransformedShape {
    [Constructor]
    void create();
    Vec3 GetShapeScale();
    void SetShapeScale(Vec3 scale);
    RMat44 GetCenterOfMassTransform();
    RMat44 GetInverseCenterOfMassTransform();
    RMat44 GetWorldTransform();
};

// ===== Shape =====

[CppClass="JPH::Shape", NoDelete]
interface Shape {
    unsigned long GetRefCount();
    void AddRef();
    void Release();
    EShapeType GetType();
    EShapeSubType GetSubType();
    boolean MustBeStatic();
    Vec3 GetCenterOfMass();
    float GetInnerRadius();
    float GetVolume();
    unsigned long long GetUserData();
    void SetUserData(unsigned long long data);
    MassProperties GetMassProperties();
};

[CppClass="JPH::ShapeSettings", NoDelete]
interface ShapeSettings {
    unsigned long GetRefCount();
    void AddRef();
    void Release();
    ShapeResult Create();
    void ClearCachedResult();
};

[CppClass="JPH::ShapeSettings::ShapeResult", ValueType]
interface ShapeResult {
    boolean IsValid();
    boolean HasError();
    Shape Get();
    void Clear();
};

// ===== Convex shapes =====

[CppClass="JPH::ConvexShapeSettings", NoDelete]
interface ConvexShapeSettings : ShapeSettings {
};

[CppClass="JPH::ConvexShape", NoDelete]
interface ConvexShape : Shape {
};

[CppClass="JPH::BoxShapeSettings"]
interface BoxShapeSettings : ConvexShapeSettings {
    [Constructor]
    void create(Vec3 halfExtent);
};

[CppClass="JPH::BoxShape", NoDelete]
interface BoxShape : ConvexShape {
    Vec3 GetHalfExtent();
};

[CppClass="JPH::SphereShapeSettings"]
interface SphereShapeSettings : ConvexShapeSettings {
    [Constructor]
    void create(float radius);
};

[CppClass="JPH::SphereShape", NoDelete]
interface SphereShape : ConvexShape {
    float GetRadius();
};

[CppClass="JPH::CapsuleShapeSettings"]
interface CapsuleShapeSettings : ConvexShapeSettings {
    [Constructor]
    void create(float halfHeightOfCylinder, float radius);
};

[CppClass="JPH::CapsuleShape", NoDelete]
interface CapsuleShape : ConvexShape {
    float GetRadius();
    float GetHalfHeightOfCylinder();
};

[CppClass="JPH::CylinderShapeSettings"]
interface CylinderShapeSettings : ConvexShapeSettings {
    [Constructor]
    void create(float halfHeight, float radius);
};

[CppClass="JPH::CylinderShape", NoDelete]
interface CylinderShape : ConvexShape {
    float GetRadius();
    float GetHalfHeight();
};

[CppClass="JPH::TaperedCapsuleShapeSettings"]
interface TaperedCapsuleShapeSettings : ConvexShapeSettings {
    [Constructor]
    void create(float halfHeightOfTaperedCylinder, float topRadius, float bottomRadius);
};

[CppClass="JPH::TaperedCapsuleShape", NoDelete]
interface TaperedCapsuleShape : ConvexShape {
    float GetHalfHeight();
    float GetTopRadius();
    float GetBottomRadius();
};

[CppClass="JPH::TaperedCylinderShapeSettings"]
interface TaperedCylinderShapeSettings : ConvexShapeSettings {
    [Constructor]
    void create(float halfHeight, float topRadius, float bottomRadius);
};

[CppClass="JPH::TaperedCylinderShape", NoDelete]
interface TaperedCylinderShape : ConvexShape {
    float GetHalfHeight();
    float GetTopRadius();
    float GetBottomRadius();
    float GetConvexRadius();
};

[CppClass="JPH::ConvexHullShapeSettings"]
interface ConvexHullShapeSettings : ConvexShapeSettings {
    [Constructor]
    void create();
};

[CppClass="JPH::ConvexHullShape", NoDelete]
interface ConvexHullShape : ConvexShape {
};

// ===== Compound shapes =====

[CppClass="JPH::CompoundShape::SubShape", NoDelete]
interface CompoundShapeSubShape {
    Vec3 GetPositionCOM();
    Quat GetRotation();
};

[CppClass="JPH::CompoundShapeSettings", NoDelete]
interface CompoundShapeSettings : ShapeSettings {
};

[CppClass="JPH::CompoundShape", NoDelete]
interface CompoundShape : Shape {
