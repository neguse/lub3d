    void SetPressure(float pressure);
    boolean GetUpdatePosition();
    void SetUpdatePosition(boolean updatePosition);
    boolean GetEnableSkinConstraints();
    void SetEnableSkinConstraints(boolean enableSkinConstraints);
    float GetSkinnedMaxDistanceMultiplier();
    void SetSkinnedMaxDistanceMultiplier(float skinnedMaxDistanceMultiplier);
    float GetVertexRadius();
    void SetVertexRadius(float vertexRadius);
    AABox GetLocalBounds();
};

